# Environment Variables untuk Development
NODE_ENV=development
PORT=3001

# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=ypwi_db
DB_PORT=3306

# JWT Secret (generate dengan: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=your_jwt_secret_key_here_change_this_in_production

# CORS Configuration (comma-separated origins)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000,http://127.0.0.1:3001

# WhatsApp API (Development - Mock)
WHATSAPP_DEVICE_ID=mock_device_id
WHATSAPP_API_URL=https://app.whacenter.id/api/send

# File Upload
UPLOAD_PATH=uploads
MAX_FILE_SIZE=10485760

# Logging
LOG_LEVEL=debug
LOG_FILE=logs/app.log